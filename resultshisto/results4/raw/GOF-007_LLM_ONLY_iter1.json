{
  "pattern": "Memento + Observer",
  "patterns": ["Memento", "Observer"],
  "classes": [
    {
      "id": "Document",
      "name": "Document",
      "type": "class",
      "attributes": ["+ id: int", "+ content: String"],
      "methods": ["+ save(): void"]
    },
    {
      "id": "Snapshot",
      "name": "Snapshot",
      "type": "class",
      "attributes": ["+ document: Document", "+ state: Map<String,  Object>"],
      "methods": ["+ restore(): void"]
    },
    {
      "id": "DocumentController",
      "name": "DocumentController",
      "type": "abstract",
      "attributes": [],
      "methods": ["+ saveSnapshot(): Snapshot"]
    },
    {
      "id": "Toolbar",
      "name": "Toolbar",
      "type": "class",
      "attributes": [],
      "methods": []
    },
    {
      "id": "StatusBar",
      "name": "StatusBar",
      "type": "class",
      "attributes": [],
      "methods": []
    },
    {
      "id": "PreviewPanel",
      "name": "PreviewPanel",
      "type": "class",
      "attributes": [],
      "methods": []
    }
  ],
  "relationships": [
    {
      "type": "association",
      "sourceId": "DocumentController",
      "targetId": "Snapshot",
      "label": ""
    },
    {
      "type": "dependency",
      "sourceId": "Toolbar",
      "targetId": "DocumentController",
      "label": ""
    },
    {
      "type": "dependency",
      "sourceId": "StatusBar",
      "targetId": "DocumentController",
      "label": ""
    },
    {
      "type": "dependency",
      "sourceId": "PreviewPanel",
      "targetId": "DocumentController",
      "label": ""
    }
  ]
}
{
  "pattern": "Observer + Strategy",
  "patterns": ["Observer", "Strategy"],
  "classes": [
    {
      "id": "Account",
      "name": "Account",
      "type": "class",
      "attributes": ["+ balance: float", "+ riskLevel: int"],
      "methods": ["+ updateBalance(): void"]
    },
    {
      "id": "RiskManagementModule",
      "name": "RiskManagementModule",
      "type": "class",
      "attributes": ["- account: Account"],
      "methods": ["- notifyAccountChanges(): void"]
    },
    {
      "id": "FraudDetectionService",
      "name": "FraudDetectionService",
      "type": "class",
      "attributes": ["- account: Account"],
      "methods": ["- detectFraud(): void"]
    },
    {
      "id": "CustomerNotificationService",
      "name": "CustomerNotificationService",
      "type": "class",
      "attributes": ["- account: Account"],
      "methods": ["- sendNotifications(): void"]
    },
    {
      "id": "AccountBalanceObserver",
      "name": "AccountBalanceObserver",
      "type": "interface",
      "attributes": [],
      "methods": ["+ updateAccountBalance(account: Account): void"]
    },
    {
      "id": "Strategy",
      "name": "Strategy",
      "type": "class",
      "attributes": ["- account: Account"],
      "methods": ["- execute(): void"]
    }
  ],
  "relationships": [
    {
      "type": "association",
      "sourceId": "Account",
      "targetId": "RiskManagementModule"
    },
    {
      "type": "association",
      "sourceId": "Account",
      "targetId": "FraudDetectionService"
    },
    {
      "type": "association",
      "sourceId": "Account",
      "targetId": "CustomerNotificationService"
    },
    {
      "type": "dependency",
      "sourceId": "RiskManagementModule",
      "targetId": "Strategy"
    },
    {
      "type": "dependency",
      "sourceId": "FraudDetectionService",
      "targetId": "Strategy"
    },
    {
      "type": "dependency",
      "sourceId": "CustomerNotificationService",
      "targetId": "Strategy"
    }
  ]
}